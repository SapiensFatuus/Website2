{
  "name": "my-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "npm run test:site && npm run test:functions",
    "test:site": "node --test site/questions/*.test.js site/chat/*.test.js",
    "test:functions": "npm test --prefix functions",
    "preview": "vite preview",
    "deploy": "npm run build && npx firebase-tools deploy",
    "deploy:hosting": "npm run build && npx firebase-tools deploy --only hosting",
    "deploy:backend": "npx firebase-tools deploy --only functions",
    "deploy:firestore": "npx firebase-tools deploy --only firestore"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "vite": "^8.1.0"
  }
}
