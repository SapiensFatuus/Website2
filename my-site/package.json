{
  "name": "my-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run catalog:validate && vite build",
    "lint": "eslint .",
    "test": "npm run catalog:validate && npm run test:site && npm run test:functions && npm run test:rules",
    "test:site": "node --test site/questions/*.test.js site/chat/*.test.js site/catalog/*.test.js site/auth/*.test.js site/learning/learningRecords.test.js",
    "test:functions": "npm test --prefix functions",
    "test:rules": "firebase emulators:exec --only firestore \"node --test site/learning/firestore.rules.test.js\"",
    "catalog:validate": "node scripts/validateCatalog.js",
    "catalog:coverage": "node scripts/catalogCoverage.js",
    "preview": "vite preview",
    "deploy": "npm run build && npx firebase-tools deploy",
    "deploy:hosting": "npm run build && npx firebase-tools deploy --only hosting",
    "deploy:backend": "npx firebase-tools deploy --only functions",
    "deploy:firestore": "npx firebase-tools deploy --only firestore"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "katex": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^14.16.0",
    "globals": "^17.6.0",
    "vite": "^8.1.0"
  }
}
