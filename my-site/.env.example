# Safe default: no network AI call and no credential required.
VITE_CHAT_MODE=mock

# Use the deployed callable or local Functions emulator.
# VITE_CHAT_MODE=firebase
# VITE_USE_FUNCTIONS_EMULATOR=true

# Public App Check site key (never put the Gemini API key here).
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your-public-site-key
