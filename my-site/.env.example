# Safe default: no network AI call and no credential required.
VITE_CHAT_MODE=mock

# Use deployed Firebase services.
# VITE_CHAT_MODE=firebase

# Connect Auth, Firestore, Functions, Storage, and the /api Vite proxy to the
# Firebase Emulator Suite. This also switches the tutor from mock protocol to
# Firebase callable protocol.
# VITE_USE_FIREBASE_EMULATORS=true

# Individual emulator flags are also supported when only one service is needed.
# VITE_USE_AUTH_EMULATOR=true
# VITE_USE_FIRESTORE_EMULATOR=true
# VITE_USE_FUNCTIONS_EMULATOR=true
# VITE_USE_STORAGE_EMULATOR=true

# Force tracker /api calls outside a production build. Normally local mock mode
# displays zeroed development counters instead of making live writes.
# VITE_TRACKER_MODE=firebase

# Public App Check site key. Vertex AI uses the function's service account, not a browser credential.
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your-public-site-key

# Development only. Use "true" to print a generated debug token in the browser
# console, or paste a registered App Check debug token. Ignored in production.
# VITE_APPCHECK_DEBUG_TOKEN=true

# Development only. Exposes draft Unit 7 lessons, formulas, stimuli, rubrics,
# and questions through explicitly labeled editorial-preview screens.
# VITE_EDITORIAL_PREVIEW=true
